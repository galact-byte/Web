# 数据库连接
DATABASE_URL=sqlite:///./app.db

# 应用端口
APP_PORT=8011

# 公网访问地址（用于生成采集链接等）
PUBLIC_BASE_URL=http://127.0.0.1:8011

# 认证配置
API_AUTH_REQUIRED=1
# AUTH_SESSION_HOURS=24

# 默认账号密码（首次启动时创建；未设置时默认使用 admin123 / tester123 / leader123）
# DEFAULT_ADMIN_PASSWORD=admin123
# DEFAULT_TESTER_PASSWORD=tester123
# DEFAULT_LEADER_PASSWORD=leader123

# SMTP 邮件配置（工作流提醒用）
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_TLS=1
# SMTP_SSL=0
