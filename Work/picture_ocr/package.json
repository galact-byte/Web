{
  "name": "picture_ocr",
  "private": true,
  "version": "0.4.4",
  "description": "测评证据采集工具",
  "author": "galact",
  "repository": {
    "type": "git",
    "url": "https://github.com/galact-byte/Web.git"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-pwa-icons.mjs",
    "build": "tsc -b && vite build && node scripts/generate-service-worker.mjs",
    "preview": "vite preview",
    "verify:evidence-package": "node scripts/verify-evidence-package.mjs",
    "verify:lan-server": "node scripts/verify-lan-server.cjs",
    "verify:lan-mobile-picker": "node scripts/verify-lan-mobile-picker.mjs",
    "verify:web-lan-server": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-web-lan-server.ps1",
    "verify:pwa-build": "node scripts/verify-pwa-build.mjs",
    "desktop:build": "npm run build && npm run desktop:clean && electron-builder --win --dir",
    "desktop:pack": "npm run build && npm run desktop:clean && electron-builder --win --publish never",
    "desktop:clean": "node -e \"require('fs').rmSync('desktop-dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "docx": "^9.7.1",
    "jszip": "^3.10.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  },
  "build": {
    "appId": "com.galact.pictureocr",
    "productName": "测评证据采集工具",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "artifactName": "${name}-${version}.${ext}",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "galact-byte",
        "repo": "Web"
      }
    ]
  }
}
