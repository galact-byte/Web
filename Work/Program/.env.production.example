# Copy this file to .env.production and change all secrets before deployment.

# ---- Image sources ----
# If Docker Hub is slow or blocked, replace these with equivalent images from your registry.
PYTHON_IMAGE=python:3.12-slim
NODE_IMAGE=node:22-alpine
NGINX_IMAGE=nginx:alpine
POSTGRES_IMAGE=postgres:16-alpine

# ---- Public ports ----
# HTTP_PORT 仅用于 80->443 跳转；实际访问走 HTTPS_PORT。
HTTP_PORT=80
HTTPS_PORT=443

# 自签名证书的 Common Name（可选）。可填服务器公网 IP 或域名，便于辨识，
# 留空则用 localhost。证书在前端容器首次启动时自动生成，无需手动制作。
SSL_CN=localhost

# ---- PostgreSQL ----
POSTGRES_DB=project_completion
POSTGRES_USER=project_user
POSTGRES_PASSWORD=change-this-database-password

# ---- Backend security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 允许跨域的来源（scheme + host，需与浏览器地址栏一致）。
# 部署内置 HTTPS 后填 https://<服务器IP或域名>，多个用逗号分隔。
# 注：前端经 Nginx 同源代理 /api，正常访问不触发跨域；此项主要对外部直连 API 生效。
CORS_ORIGINS=https://localhost

# Initial admin password used only when the database is empty.
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
