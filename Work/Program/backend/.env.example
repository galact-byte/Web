# 环境配置文件示例
# 复制此文件为 .env 并修改相应值

# ---- 环境模式 ----
# dev = 开发模式（启用 Swagger 文档，使用默认密钥）
# prod = 生产模式（禁用 Swagger 文档，强制要求设置 SECRET_KEY）
ENV=dev

# ---- 数据库配置 ----
# 开发环境使用 SQLite（默认）
# DATABASE_URL=sqlite:///./project_completion.db

# 生产环境使用 PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/project_db

# ---- JWT 安全配置 ----
# 生产环境必须设置一个强随机密钥（至少 32 字符）
# 可用命令生成: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS 配置 ----
# 允许的前端来源地址，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- 初始管理员密码 ----
# 首次启动时创建 admin 账户所使用的密码
# 若不设置：开发模式默认 admin123，生产模式随机生成（仅在控制台输出一次）
# 强烈建议在生产环境部署前设置此项！
DEFAULT_ADMIN_PASSWORD=

# ---- 服务配置 ----
HOST=0.0.0.0
PORT=8000
